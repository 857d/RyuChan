---
const { slug, encryptedContent, password } = Astro.props;
---

{
  password ? (
    <div id={`encrypted-post-${slug}`} data-encrypted={encryptedContent} data-password={password} data-slug={slug}>
      <!-- 编辑按钮（初始隐藏，解密后显示） -->
      <div id="edit-button-container" class="flex justify-end mb-4" style="display: none;">
        <a href={`/write?slug=${slug}`} class="btn btn-primary btn-sm text-white" aria-label="Edit Article">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 3l4 4-7 7H10v-4l7-7z M14 6l4 4"></path>
          </svg>
          <span class="hidden sm:inline">Edit</span>
        </a>
      </div>

      <!-- 密码输入卡片 -->
      <div class="password-card" style="max-width: 28rem; margin: 2rem auto;">
        <div class="card bg-base-100 shadow-xl border border-base-200">
          <div class="card-body items-center text-center">
            <div class="text-4xl mb-2">🔐</div>
            <h2 class="card-title text-xl">此文章已加密</h2>
            <p class="text-sm text-base-content/70 mb-4">请输入密码查看内容</p>
            <div class="form-control w-full max-w-xs">
              <input type="password" id="password-input" placeholder="密码" class="input input-bordered w-full mb-4" autofocus />
              <button id="decrypt-btn" class="btn btn-primary">验证</button>
            </div>
            <div id="error-msg" class="text-error text-sm mt-2 hidden"></div>
          </div>
        </div>
      </div>

      <!-- 解密后内容容器 -->
      <div class="decrypted-content" style="display: none;"></div>
    </div>
  ) : (
    <p>⚠️ 此文章未设置密码，无法加密。</p>
  )
}

<script src="/decrypt.js" is:inline></script>
