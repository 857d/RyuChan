---
const { slug, encryptedContent, password } = Astro.props;
---

{
  password ? (
    <div data-encrypted={encryptedContent} data-password={password}>
      <div class="password-card" style="border:2px solid red; padding:20px;">
        <h2>加密文章</h2>
        <input type="password" id="pwd" />
        <button id="decrypt">验证</button>
        <div id="err"></div>
      </div>
      <div class="decrypted-content" style="display:none;"></div>
    </div>
  ) : (
    <p style="color:red">未设置密码！</p>
  )
}

<script is:inline>
  const container = document.currentScript.closest('[data-encrypted]');
  const stored = container?.getAttribute('data-password');
  const encrypted = container?.getAttribute('data-encrypted');
  const btn = document.getElementById('decrypt');
  const input = document.getElementById('pwd');
  const err = document.getElementById('err');
  const decryptedDiv = container?.querySelector('.decrypted-content');
  btn.onclick = async () => {
    const val = input.value.trim();
    if (!val) { err.innerText = '请输入密码'; return; }
    if (val !== stored) { err.innerText = '密码错误'; return; }
    // 解密函数略，请从之前版本复制 decryptWithWebCrypto
    // 成功后显示 decryptedDiv
  };
</script>
