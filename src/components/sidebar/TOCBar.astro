---
import { Icon } from "astro-icon/components";
import Card from "../temple/Card.astro";
import type { TOCBarProps } from "@interfaces/data";

const { headings = [], showTOC = true } = Astro.props as TOCBarProps;
---

{
  showTOC && headings.length > 0 && (
    <div id="toc-container" class="mt-4 z-10 md:max-h-[calc(100vh-2rem)] ">
      <Card>
        <div class="p-4">
          <nav class="toc-nav max-h-[calc(100vh-200px)] overflow-y-auto scrollbar-none">
            <ul class="space-y-0">
              {headings.map((heading, index) => (
                <li>
                  <a
                    href={`#heading-${index}`}
                    data-heading-depth={heading.depth}
                    class={`toc-link relative flex items-center py-2 px-2 rounded-lg ${heading.depth === 1 ? "font-medium" : ""}`}
                    style={`padding-left: ${12 + (heading.depth - 1) * 16}px;`}
                  >
                    <Icon
                      name="tabler:chevron-right"
                      class="icon-indicator absolute left-1 opacity-0 transition-all duration-200 w-4 h-4 text-primary"
                    />
                    <span class="link-text transition-transform duration-200">{heading.text}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </Card>
    </div>
  )
}

<style>
  .toc-link:hover .link-text {
    transform: translateX(2px);
  }

  .toc-link.active {
    color: var(--p);
    font-weight: 500;
  }

  .toc-link.active .icon-indicator {
    opacity: 1;
    transform: translateX(1px);
  }

  .toc-link:hover .icon-indicator {
    opacity: 0.5;
  }
</style>

<script>
  // ========== 用户可修改的偏移量 ==========
  // 1. 导航栏高度（单位：px）—— 请根据您的实际导航栏高度修改
  const NAVBAR_HEIGHT = 80;   // 👈 改成您网页顶部导航栏的实际高度（例如 64、72）
  // 2. 点击跳转时的额外偏移（正值让标题更靠下，负值更靠上）
  const EXTRA_OFFSET = 10;    // 👈 微调，通常保持 10 左右
  // =====================================

  function generateHeadingIds() {
    document.querySelectorAll('h1, h2, h3, h4, h5, h6').forEach((heading, idx) => {
      if (!heading.id) {
        let slug = (heading.textContent || '').trim()
          .toLowerCase()
          .replace(/[^\w\u4e00-\u9fa5]+/g, '-')
          .replace(/^-+|-+$/g, '');
        if (!slug) slug = `heading-${idx}`;
        if (document.getElementById(slug)) slug = `${slug}-${idx}`;
        heading.id = slug;
      }
    });
  }

  function fixTOCLinks() {
    const tocLinks = document.querySelectorAll('.toc-nav a');
    const headings = document.querySelectorAll('h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]');
    // 将标题 id 统一为 heading-0, heading-1... 并与目录链接匹配
    headings.forEach((heading, idx) => {
      const newId = `heading-${idx}`;
      if (heading.id !== newId) heading.id = newId;
    });
    tocLinks.forEach((link, idx) => {
      link.setAttribute('href', `#heading-${idx}`);
    });
    return { tocLinks, headings };
  }

  function bindEvents(tocLinks, headings) {
    // 点击跳转
    tocLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.getAttribute('href').slice(1);
        const target = document.getElementById(targetId);
        if (target) {
          const targetPosition = target.getBoundingClientRect().top + window.scrollY - NAVBAR_HEIGHT - EXTRA_OFFSET;
          window.scrollTo({ top: targetPosition, behavior: 'smooth' });
          history.pushState(null, null, `#${targetId}`);
        }
      });
    });

    // 滚动高亮
    function updateActive() {
      const offset = NAVBAR_HEIGHT + 20; // 高亮触发区域（可调）
      let currentId = '';
      for (const heading of headings) {
        const rect = heading.getBoundingClientRect();
        if (rect.top <= offset && rect.bottom >= offset) {
          currentId = heading.id;
          break;
        }
      }
      tocLinks.forEach(link => {
        link.classList.remove('active');
        if (link.getAttribute('href') === `#${currentId}`) {
          link.classList.add('active');
        }
      });
    }

    window.addEventListener('scroll', updateActive);
    window.addEventListener('load', updateActive);
    updateActive();
  }

  function init() {
    generateHeadingIds();
    const { tocLinks, headings } = fixTOCLinks();
    if (tocLinks.length === 0 || headings.length === 0) return;
    bindEvents(tocLinks, headings);
  }

  // 支持 Astro 页面切换和普通加载
  document.addEventListener('astro:page-load', () => setTimeout(init, 50));
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
