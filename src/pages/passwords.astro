---
// src/pages/passwords.astro
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const encryptedPosts = allPosts
  .filter(post => post.data.password && typeof post.data.password === 'string' && post.data.password.trim() !== '')
  .map(post => ({
    title: post.data.title,
    slug: post.slug,
    password: post.data.password,
    pubDate: post.data.pubDate,
  }))
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

const adminPassword = import.meta.env.ADMIN_PASSWORD || '';
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>加密文章密码管理</title>
  <meta name="robots" content="noindex, nofollow">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .copy-btn { cursor: pointer; transition: all 0.2s; }
    .copy-btn:hover { background-color: #3b82f6; color: white; }
  </style>
</head>
<body class="bg-gray-100 min-h-screen">
  <div class="max-w-5xl mx-auto p-4 md:p-6">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <div class="bg-gradient-to-r from-red-600 to-red-700 px-6 py-5">
        <h1 class="text-2xl md:text-3xl font-bold text-white flex items-center gap-2">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
          </svg>
          加密文章密码管理
        </h1>
        <p class="text-red-100 text-sm mt-1">数据更新时间：{new Date().toLocaleString()}</p>
      </div>

      <div id="auth-panel" class="p-6">
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-yellow-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            <span class="text-yellow-800 text-sm">此页面受密码保护，请输入管理员密码查看</span>
          </div>
        </div>
        <div class="max-w-md mx-auto">
          <label class="block text-sm font-medium text-gray-700 mb-2">管理员密码</label>
          <input type="password" id="admin-password" class="w-full border rounded-lg px-4 py-2 mb-4" placeholder="请输入管理员密码" autofocus />
          <button id="verify-btn" class="w-full bg-red-600 hover:bg-red-700 text-white py-2 rounded-lg transition">验证</button>
          <p id="error-msg" class="text-red-500 text-sm mt-3 hidden text-center"></p>
        </div>
      </div>

      <div id="password-container" class="p-4" style="display: none;">
        {encryptedPosts.length === 0 ? (
          <div class="text-center py-8 text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            <p>暂无加密文章</p>
          </div>
        ) : (
          <>
            <div class="overflow-x-auto">
              <table class="min-w-full border-collapse">
                <thead class="bg-gray-100">
                  <tr>
                    <th class="px-4 py-3 text-left text-sm font-semibold">标题</th>
                    <th class="px-4 py-3 text-left text-sm font-semibold">slug</th>
                    <th class="px-4 py-3 text-left text-sm font-semibold">密码</th>
                    <th class="px-4 py-3 text-left text-sm font-semibold">发布日期</th>
                    <th class="px-4 py-3 text-left text-sm font-semibold">操作</th>
                  </tr>
                </thead>
                <tbody>
                  {encryptedPosts.map(post => (
                    <tr class="border-b hover:bg-gray-50">
                      <td class="px-4 py-3 text-sm">{post.title}</td>
                      <td class="px-4 py-3 text-sm font-mono">{post.slug}</td>
                      <td class="px-4 py-3">
                        <div class="flex items-center gap-2">
                          <span class="font-mono text-sm bg-gray-100 px-2 py-1 rounded">{post.password}</span>
                          <button onclick="copyPassword('{post.password}')" class="copy-btn text-xs bg-gray-200 hover:bg-blue-600 hover:text-white px-2 py-1 rounded transition">📋 复制</button>
                        </div>
                      </td>
                      <td class="px-4 py-3 text-sm">{new Date(post.pubDate).toLocaleDateString()}</td>
                      <td class="px-4 py-3">
                        <a href={`/blog/${post.slug}`} target="_blank" class="text-blue-600 hover:text-blue-800 text-sm">🔗 查看</a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="text-sm text-gray-500 mt-4">共 {encryptedPosts.length} 篇加密文章</p>
          </>
        )}
      </div>
    </div>
  </div>

  <script>
    const ADMIN_PASSWORD = "{adminPassword}";
    const container = document.getElementById('password-container');
    const authPanel = document.getElementById('auth-panel');
    const verifyBtn = document.getElementById('verify-btn');
    const passwordInput = document.getElementById('admin-password');
    const errorMsg = document.getElementById('error-msg');

    if (sessionStorage.getItem('admin_verified') === 'true' && ADMIN_PASSWORD) {
      authPanel.style.display = 'none';
      container.style.display = 'block';
    }

    verifyBtn.addEventListener('click', () => {
      const entered = passwordInput.value;
      if (entered === ADMIN_PASSWORD) {
        sessionStorage.setItem('admin_verified', 'true');
        authPanel.style.display = 'none';
        container.style.display = 'block';
        errorMsg.classList.add('hidden');
      } else {
        errorMsg.textContent = '管理员密码错误，无权查看！';
        errorMsg.classList.remove('hidden');
      }
    });

    passwordInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') verifyBtn.click();
    });

    function copyPassword(password) {
      navigator.clipboard.writeText(password);
      alert('密码已复制: ' + password);
    }
  </script>
</body>
</html>
